# Core namespace support
CONFIG_NAMESPACES=y
CONFIG_PID_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y

CONFIG_CGROUP_NS=y
CONFIG_SCHED_AUTOGROUP=y
CONFIG_SYSVIPC=y

# Addon KPROBES
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y

# Addon BPF
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_EBPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_BPF_KPROBE_OVERRIDE=y

# FS Support
CONFIG_NTFS_FS=y
CONFIG_UDF_FS=y
CONFIG_NTFS_RW=y
CONFIG_ISO9660_FS=y

# Werror
CONFIG_CC_WERROR=n

# other
CONFIG_MODULE_SIG=y

# kpm
CONFIG_KPM=y
  
